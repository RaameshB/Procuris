# =============================================================================
# Supply Chain Data Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real credentials.
#   cp .env.example .env
# NEVER commit the .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL (matches docker-compose.yml defaults)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=hackathonpassword
POSTGRES_DB=supplychain_db


# -----------------------------------------------------------------------------
# Polygon.io
# Free tier: 5 API calls / minute (the pipeline enforces a 12 s sleep).
# Sign up at: https://polygon.io/
# -----------------------------------------------------------------------------
POLYGON_API_KEY=pAfcdp4HhdUBuUC2gX9zifxsZDXWP7mn


# -----------------------------------------------------------------------------
# US Census Bureau
# Free, but a key is required for higher rate limits.
# Request a key at: https://api.census.gov/data/key_signup.html
# -----------------------------------------------------------------------------
CENSUS_API_KEY=792ffa0a7c415502085fa45787085f1557a79103


# -----------------------------------------------------------------------------
# OpenSky Network
# Anonymous access is allowed but rate-limited to 10 s between calls.
# Authenticated users get 5 s intervals and access to more data fields.
# Register at: https://opensky-network.org/index.php?option=com_users&view=registration
# Leave blank to use anonymous (unauthenticated) access.
# -----------------------------------------------------------------------------
OPENSKY_USERNAME=raameshb-api-client
OPENSKY_PASSWORD=vRIWBE72UWx6IBjdCobKDW73j60eNs7x

# -----------------------------------------------------------------------------
# FRED (St. Louis Fed)
# Free API key for economic data series.
# Get a key at: https://fred.stlouisfed.org/docs/api/api_key.html
# -----------------------------------------------------------------------------
FRED_API_KEY=98c58d5d1f343c63937756f340235232

# -----------------------------------------------------------------------------
# UN Comtrade (API v1)
# Free Basic tier gives 500 requests per day, 100k records per request.
# Get a subscription key at: https://comtradeplus.un.org/
# -----------------------------------------------------------------------------
COMTRADE_API_KEY=your_comtrade_api_key_here

