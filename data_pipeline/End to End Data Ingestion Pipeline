    )


# =============================================================================
# ── Stage 1: Playwright — Scrape raw page text ────────────────────────────────
# =============================================================================


def _build_browser_context(playwright: Playwright) -> tuple[Browser, BrowserContext]:
    """
    Launch a headless Chromium browser and return (browser, context).

    The context is configured with a realistic user-agent and viewport to
    reduce the likelihood of bot-detection triggers on JS-heavy sites.

    Args:
        playwright: The sync Playwright instance.

    Returns:
        A (Browser, BrowserContext) tuple. The caller is responsible for
        closing both when done.
    """
    browser = playwright.chromium.launch(
        headless=True,
        args=[
            "--disable-blink-features=AutomationControlled",
            "--no-sandbox",
            "--disable-dev-shm-usage",
        ],
    )
    context = browser.new_context(
        user_agent=(
            "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
            "AppleWebKit/537.36 (KHTML, like Gecko) "
            "Chrome/124.0.0.0 Safari/537.36"
        ),
        viewport={"width": 1280, "height": 900},
        # Disable WebRTC to avoid IP leaks that could trigger bot detection
        java_script_enabled=True,
        bypass_csp=False,
    )
    # Mask the `navigator.webdriver` property that headless Chrome exposes
    context.add_init_script(
        "Object.defineProperty(navigator, 'webdriver', {get: () => undefined})"
    )
    return browser, context


def _attempt_login(page: Page) -> bool:
    """
    Try to log into Import Genius using credentials from .env.

    The function navigates to the login page, fills the email and password
    fields, submits the form, and waits for the page to stabilise. Returns
    True if the login *appears* successful (no error banner detected), False
    otherwise.

    Import Genius uses a standard Rails Devise form. The CSS selectors used
    here target the default Devise markup — update them if the site redesigns.

    Args:
        page: An active Playwright Page object.

    Returns:
        True if login succeeded (or was already authenticated), False on error.
    """
    username = os.getenv("IMPORT_GENIUS_USERNAME", "").strip()
    password = os.getenv("IMPORT_GENIUS_PASSWORD", "").strip()

    if not username or not password:
        logger.warning(
            "[Playwright] IMPORT_GENIUS_USERNAME / IMPORT_GENIUS_PASSWORD "
            "not set in .env. Skipping login — scraping may fail if the "
            "target pages require authentication."
        )
        return False

    logger.info("[Playwright] Attempting Import Genius login as '%s' …", username)

    try:
        page.goto(IMPORT_GENIUS_LOGIN_URL, timeout=NAV_TIMEOUT_MS, wait_until="networkidle")

        # ── Fill credentials ─────────────────────────────────────────────────
        # Selectors for Devise email/password form (adjust if site updates)
        page.fill('input[type="email"], input[name="user[email]"]',    username)
        page.fill('input[type="password"], input[name="user[password]"]', password)

        # ── Submit form ───────────────────────────────────────────────────────
        page.click('input[type="submit"], button[type="submit"]')
        page.wait_for_load_state("networkidle", timeout=NAV_TIMEOUT_MS)

        # ── Check for error indicators ────────────────────────────────────────
        error_selectors = [
            ".alert-danger",
            ".flash-error",
            '[data-testid="login-error"]',
            "text=Invalid Email or password",
        ]
        for selector in error_selectors:
            if page.locator(selector).count() > 0:
                logger.error(
                    "[Playwright] Login failed — error element found: '%s'. "
                    "Check IMPORT_GENIUS_USERNAME / IMPORT_GENIUS_PASSWORD.",
                    selector,
                )
                return False

        logger.info("[Playwright] Login succeeded.")
        return True

    except PlaywrightTimeoutError:
        logger.error("[Playwright] Timeout waiting for login page / post-login redirect.")
        return False
    except Exception as exc:
        logger.error("[Playwright] Unexpected error during login: %s", exc)
        return False


def scrape_page_text(url: str, page: Page) -> str | None:
    """
    Navigate to ``url`` with the given Playwright page and extract all visible
    body text, truncated to ``MAX_TEXT_CHARS``.

    The function waits for ``networkidle`` (no network activity for 500 ms)
    then adds a fixed delay to allow any deferred JavaScript rendering to
    complete — common on data-table heavy pages.

    Args:
        url:  Target URL.
        page: An authenticated (or anonymous) Playwright Page object.

    Returns:
        The extracted body text string, or None on navigation failure.
    """
    logger.info("[Playwright] Navigating to: %s", url)

    try:
        page.goto(url, timeout=NAV_TIMEOUT_MS, wait_until="networkidle")

        # Extra settle time for lazy-loaded data tables
        page.wait_for_timeout(WAIT_AFTER_NAV_MS)

        # ── Try targeted selectors first for cleaner extraction ───────────────
        # Import Genius data tables live in elements with these classes/IDs.
        # If none match we fall back to full body text.
        targeted_selectors = [
            "#shipments-table",
            ".shipments-list",
            ".results-table",
            '[data-testid="shipment-results"]',
            "table.table",
            "main",           # semantic main content area
        ]

        extracted_text: str | None = None
        for selector in targeted_selectors:
            try:
                locator = page.locator(selector).first
                if locator.count() > 0:
                    extracted_text = locator.inner_text(timeout=5_000)
                    logger.info(
                        "[Playwright] Extracted text via selector '%s' (%d chars).",
                        selector, len(extracted_text),
                    )
                    break
            except PlaywrightTimeoutError:
                continue

        # Fallback: grab all body text
        if not extracted_text:
            extracted_text = page.inner_text("body")
            logger.info(
                "[Playwright] Extracted full body text (%d chars) from %s.",
                len(extracted_text), url,
            )

        return extracted_text.strip() if extracted_text else None

    except PlaywrightTimeoutError:
        logger.error("[Playwright] Timeout navigating to: %s", url)
        return None
    except Exception as exc:
        logger.error("[Playwright] Unexpected error scraping %s: %s", url, exc)
        return None


# =============================================================================
# ── Stage 2: Ollama — Parse raw text into structured Pydantic models ──────────
# =============================================================================

# System prompt: establishes the model's role and output contract.
_SYSTEM_PROMPT = """\
You are an expert supply-chain data extraction agent specialised in customs records.
Your task is to read raw text scraped from a trade-intelligence platform and extract
every identifiable shipment record into structured JSON.

Extraction rules:
1. Return ONLY a single JSON object that conforms to the provided schema.
2. Use null (JSON null, not the string "null") for any field you cannot determine.
3. Do NOT hallucinate values — only extract what is explicitly present in the text.
4. If the text contains no shipment data (e.g. it is a login wall or an error page),
   return a batch with an empty `records` list and explain in `extraction_notes`.
5. Normalise dates to YYYY-MM-DD format wherever possible.
6. Normalise weights to kilograms; volumes to cubic metres.
7. Use ISO 3166-1 alpha-2 country codes (e.g. "CN", "US") where identifiable.\
"""


def _build_user_prompt(raw_text: str, source_url: str) -> str:
    """
    Construct the user-turn prompt that includes the scraped page text.

    The text is truncated to MAX_TEXT_CHARS before embedding in the prompt to
    stay within the model's context window.

    Args:
        raw_text:   Raw text content from Playwright.
        source_url: URL the text was scraped from (included for provenance).

    Returns:
        A formatted prompt string.
    """
    truncated = raw_text[:MAX_TEXT_CHARS]
    if len(raw_text) > MAX_TEXT_CHARS:
        logger.warning(
            "[Ollama] Page text truncated from %d to %d chars to fit context window.",
            len(raw_text), MAX_TEXT_CHARS,
        )

    return (
        f"Source URL: {source_url}\n\n"
        "Raw scraped text:\n"
        "---\n"
        f"{truncated}\n"
        "---\n\n"
        "Extract all shipment records from the text above."
    )


def parse_with_ollama(raw_text: str, source_url: str) -> ShipmentBatch | None:
    """
    Send the scraped ``raw_text`` to the locally running Ollama model and
    return a validated :class:`ShipmentBatch`.

    The ``format`` parameter passes the full JSON Schema of ``ShipmentBatch``
    directly to Ollama, which instructs the model (and the Ollama runtime's
    constrained decoding layer) to return output that is *guaranteed* to be
    valid JSON conforming to that schema — even if the model would otherwise
    generate free text.

    Args:
        raw_text:   Text content extracted by Playwright.
        source_url: Source URL (embedded in the prompt for provenance).

    Returns:
        A validated :class:`ShipmentBatch`, or None if parsing fails.
    """
    if not raw_text or not raw_text.strip():
        logger.warning("[Ollama] Empty text passed for %s — skipping.", source_url)
        return None

    user_prompt = _build_user_prompt(raw_text, source_url)

    logger.info(
        "[Ollama] Sending %d chars to model '%s' …",
        len(user_prompt), OLLAMA_MODEL,
    )

    try:
        # Configure the Ollama client host (allows non-default ports / remote)
        ollama_client = ollama.Client(host=OLLAMA_HOST)

        response = ollama_client.chat(
            model=OLLAMA_MODEL,
            messages=[
                {"role": "system", "content": _SYSTEM_PROMPT},
                {"role": "user",   "content": user_prompt},
            ],
            # Pass the full Pydantic JSON Schema to force structured output.
            # Ollama uses this to constrain the token sampling process so the
            # output always parses as valid JSON matching this schema.
            format=ShipmentBatch.model_json_schema(),
            options={
                "temperature": 0.0,   # Deterministic: no creative improvisation
                "num_predict": 4096,  # Max tokens to generate in the response
            },
        )

    except ollama.ResponseError as exc:
        logger.error(
            "[Ollama] Model response error (model='%s'): %s. "
            "Is the model pulled? Run: ollama pull %s",
            OLLAMA_MODEL, exc, OLLAMA_MODEL,
        )
        return None
    except Exception as exc:
        logger.error(
            "[Ollama] Unexpected error calling model '%s': %s",
            OLLAMA_MODEL, exc,
        )
        return None

    # ── Extract raw JSON string from the response ─────────────────────────────
    raw_json: str = response["message"]["content"]

    if not raw_json or not raw_json.strip():
        logger.error("[Ollama] Empty response from model for URL: %s", source_url)
        return None

    logger.info(
        "[Ollama] Received %d chars of JSON from model.", len(raw_json)
    )
    logger.debug("[Ollama] Raw response:\n%s", raw_json[:500])

    # ── Validate with Pydantic ────────────────────────────────────────────────
    try:
        batch = ShipmentBatch.model_validate_json(raw_json)
        # Inject provenance: the model may not know the source URL
        batch.source_url = source_url
        logger.info(
            "[Ollama] Extracted %d shipment record(s) from %s.",
            len(batch.records), source_url,
        )
        return batch

    except Exception as exc:
        # Pydantic validation failed — log the offending JSON for debugging
        logger.error(
            "[Ollama] Pydantic validation failed for response from %s: %s\n"
            "  First 300 chars of raw JSON: %s",
            source_url, exc, raw_json[:300],
        )
        return None


# =============================================================================
# ── Conversion: ShipmentBatch → flat DataFrame ────────────────────────────────
# =============================================================================


def batch_to_dataframe(batch: ShipmentBatch) -> pd.DataFrame:
    """
    Flatten a :class:`ShipmentBatch` into a pandas DataFrame suitable for
    bulk-inserting into PostgreSQL.

    Each row corresponds to one :class:`ShipmentRecord`. Provenance columns
    (``source_url``, ``extraction_notes``, ``total_records_on_page``,
    ``scraped_at``) are appended to every row.

    Args:
        batch: A validated ShipmentBatch returned by :func:`parse_with_ollama`.

    Returns:
        A flat DataFrame, or an empty DataFrame if the batch has no records.
    """
    if not batch or not batch.records:
        logger.warning(
            "[Conversion] ShipmentBatch has no records (url=%s). "
            "Returning empty DataFrame.", batch.source_url if batch else "unknown",
        )
        return pd.DataFrame()

    rows: list[dict] = []
    for record in batch.records:
        row = record.model_dump()

        # ── Provenance / metadata ──────────────────────────────────────────
        row["source_url"]              = batch.source_url
        row["extraction_notes"]        = batch.extraction_notes
        row["total_records_on_page"]   = batch.total_records_on_page
        row["scraped_at"]              = pd.Timestamp.utcnow()
        row["ollama_model"]            = OLLAMA_MODEL

        rows.append(row)

    df = pd.DataFrame(rows)

    # Coerce date columns to datetime (best-effort; leave as string if mixed)
    for date_col in ("shipment_date", "arrival_date"):
        if date_col in df.columns:
            df[date_col] = pd.to_datetime(df[date_col], errors="coerce")

    return df


# =============================================================================
# ── Ollama health check ───────────────────────────────────────────────────────
# =============================================================================


def _check_ollama_available() -> bool:
    """
    Verify that the Ollama daemon is reachable and the target model is listed.

    Returns:
        True if Ollama is up and the model is available; False otherwise.
    """
    try:
        client = ollama.Client(host=OLLAMA_HOST)
        model_list = client.list()
        model_names: list[str] = [m["name"] for m in model_list.get("models", [])]

        logger.info("[Ollama] Daemon reachable. Available models: %s", model_names)

        # Check if our target model (or a version-tagged variant) is present
        target = OLLAMA_MODEL.split(":")[0]   # strip tag, e.g. "llama3:latest" → "llama3"
        matched = [m for m in model_names if m.split(":")[0] == target]

        if not matched:
            logger.error(
                "[Ollama] Model '%s' not found locally. "
                "Pull it with: ollama pull %s",
                OLLAMA_MODEL, OLLAMA_MODEL,
            )
            return False

        logger.info("[Ollama] Model '%s' confirmed available.", OLLAMA_MODEL)
        return True

    except Exception as exc:
        logger.error(
            "[Ollama] Cannot reach Ollama daemon at %s: %s\n"
            "  Make sure it is running with: ollama serve",
            OLLAMA_HOST, exc,
        )
        return False


# =============================================================================
# ── Orchestration entry point ─────────────────────────────────────────────────
# =============================================================================


def main() -> None:
    """
    Full pipeline:
        1. Verify Ollama is available.
        2. Connect to PostgreSQL.
        3. Launch Playwright (one browser session for all URLs).
        4. Optionally authenticate with Import Genius.
        5. For each target URL: scrape → parse → accumulate records.
        6. Write combined DataFrame to ``raw_import_genius``.
    """
    separator = "=" * 65

    logger.info(separator)
    logger.info("Supply Chain Pipeline — Import Genius Agentic Ingestion")
    logger.info(separator)

    # ── Pre-flight checks ─────────────────────────────────────────────────────
    if not _check_ollama_available():
        logger.critical(
            "Ollama is not available. Cannot proceed without a local LLM. "
            "Start Ollama with `ollama serve` and ensure the model is pulled."
        )
        return

    engine = get_engine()
    if not test_connection(engine):
        logger.critical(
            "Cannot reach the PostgreSQL database. "
            "Is docker compose up? Are the .env credentials correct?"
        )
        return

    if not IMPORT_GENIUS_URLS:
        logger.error(
            "No target URLs configured. "
            "Set IMPORT_GENIUS_URL in .env (comma-separated for multiple URLs)."
        )
        return

    logger.info(
        "Processing %d URL(s) with model '%s'.",
        len(IMPORT_GENIUS_URLS), OLLAMA_MODEL,
    )

    all_dataframes: list[pd.DataFrame] = []

    # ── Launch single Playwright session for all URLs ─────────────────────────
    with sync_playwright() as playwright:
        browser, context = _build_browser_context(playwright)

        try:
            page: Page = context.new_page()

            # Attempt login once; subsequent navigations reuse the session cookies.
            login_ok = _attempt_login(page)
            if not login_ok:
                logger.warning(
                    "[Playwright] Login was not completed. "
                    "Proceeding — unauthenticated pages may lack data."
                )

            # ── Process each target URL ────────────────────────────────────────
            for idx, url in enumerate(IMPORT_GENIUS_URLS, start=1):
                logger.info(
                    "\n%s\n[%d/%d] Processing: %s\n%s",
                    "-" * 65, idx, len(IMPORT_GENIUS_URLS), url, "-" * 65,
                )

                # Stage 1: Playwright scraping
                raw_text = scrape_page_text(url, page)
                if not raw_text:
                    logger.warning("[%d/%d] No text extracted from %s. Skipping.", idx, len(IMPORT_GENIUS_URLS), url)
                    continue

                # Stage 2: Ollama structured extraction
                batch = parse_with_ollama(raw_text, source_url=url)
                if batch is None:
                    logger.warning("[%d/%d] Ollama returned no batch for %s. Skipping.", idx, len(IMPORT_GENIUS_URLS), url)
                    continue

                # Convert to DataFrame
                df = batch_to_dataframe(batch)
                if not df.empty:
                    all_dataframes.append(df)
                    logger.info(
                        "[%d/%d] Appended %d record(s) from %s.",
                        idx, len(IMPORT_GENIUS_URLS), len(df), url,
                    )
                else:
                    logger.warning(
                        "[%d/%d] Batch from %s contained no records.",
                        idx, len(IMPORT_GENIUS_URLS), url,
                    )

                # Polite inter-URL delay
                if idx < len(IMPORT_GENIUS_URLS):
                    logger.info("Sleeping %.1f s before next URL …", INTER_URL_SLEEP)
                    time.sleep(INTER_URL_SLEEP)

        finally:
            # Always close browser resources, even on error
            try:
                context.close()
                browser.close()
                logger.info("[Playwright] Browser closed.")
            except Exception as close_exc:
                logger.warning("[Playwright] Error closing browser: %s", close_exc)

    # ── Write to PostgreSQL ───────────────────────────────────────────────────
    if not all_dataframes:
        logger.warning(
            "No data was extracted from any URL. "
            "The '%s' table will not be written. "
            "Possible causes: login failure, empty pages, or model errors.",
            TARGET_TABLE,
        )
        return

    final_df = pd.concat(all_dataframes, ignore_index=True)
    logger.info(
        "\nTotal extracted: %d record(s) across %d URL(s).",
        len(final_df), len(IMPORT_GENIUS_URLS),
    )

    write_dataframe(final_df, TARGET_TABLE, engine)

    logger.info("\n%s", separator)
    logger.info(
        "Import Genius ingestion complete. %d rows written to '%s'.",
        len(final_df), TARGET_TABLE,
    )
    logger.info(separator)


if __name__ == "__main__":
    main()

