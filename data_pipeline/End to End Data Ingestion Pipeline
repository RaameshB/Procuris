        return stripped if stripped else None

    @model_validator(mode="after")
    def _guard_all_null(self) -> "ShipmentRecord":
        """
        Warn (but do not reject) if every single field is None — this usually
        indicates the LLM failed to find any structured data in the chunk.
        The record is still kept so the caller can inspect it.
        """
        values = self.model_dump()
        non_null = [k for k, v in values.items() if v is not None]
        if not non_null:
            logger.debug("ShipmentRecord validator: all fields are null — likely an empty extract.")
        return self


class ShipmentBatch(BaseModel):
    """
    The top-level structure returned by the LLM for each scraped page.

    The model is instructed to populate ``records`` with every shipment it can
    identify in the raw text. ``extraction_notes`` gives the model a place to
    surface caveats without polluting the structured records.
    """

    records: list[ShipmentRecord] = Field(
        default_factory=list,
        description=(
            "Ordered list of individual shipment records identified in the text. "
            "Return an empty list if no shipments are found."
        ),
    )
    source_url: str | None = Field(
        default=None,
        description="URL from which the source text was scraped.",
    )
    extraction_notes: str | None = Field(
        default=None,
        description=(
            "Optional free-text notes about the extraction, e.g. "
            "'Text appeared to be a login wall' or 'Data table had 3 pages'."
        ),
    )
    total_records_on_page: int | None = Field(
        default=None,
        description=(
            "The total number of records the page claims to contain "
            "(e.g. from a pagination label like 'Showing 1-25 of 1,432'). "
            "Null if no such count is visible."
