# =============================================================================
# clean_data.py
# Supply Chain Data Pipeline — Data Cleaning & Processing
#
# Reads every raw_* table from PostgreSQL, applies a two-stage cleaning
# pipeline, and writes the result to a corresponding processed_* table.
#
# Cleaning rules (applied in order):
#   Stage 1 — Column pruning
#       Drop any column whose null-value fraction exceeds NULL_DROP_THRESHOLD
#       (default 15 %).  Dropping the whole column is safer than imputing a
#       field that is almost entirely missing, as such a column carries little
#       signal and the imputed values would be almost entirely fabricated.
#
#   Stage 2 — Numeric imputation
#       For every numeric column that survives Stage 1 and still contains
#       at least one null:
#         a) Insert a boolean  "<col>_was_null"  indicator column immediately
#            to the right of the source column.  This preserves the fact that
#            the original value was absent — downstream models / analyses can
#            use the flag as a feature.
#         b) Fill nulls in the source column with the column median.
#            The median is robust to outliers and requires no distributional
#            assumptions, making it the right default for financial and
#            sensor time-series data.
#
#   Non-numeric (string / boolean / datetime) columns with nulls are left as-
#   is after Stage 1; they are intentionally NOT imputed because replacing a
#   missing country name with a mode value would introduce misleading data.
#
#   Rows are NEVER dropped.
#
# Run:
#   uv run python data_pipeline/clean_data.py          (from repo root)
#   uv run clean_data.py                               (from data_pipeline/)
# =============================================================================

from __future__ import annotations

import logging
from pathlib import Path
from typing import NamedTuple

import pandas as pd
from dotenv import load_dotenv
from sqlalchemy.engine import Engine

from db_utils import (
    get_engine,
    list_tables,
    read_table,
    test_connection,
    write_dataframe,
)

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
_ENV_FILE = Path(__file__).parent / ".env"
load_dotenv(dotenv_path=_ENV_FILE, override=False)

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
    datefmt="%Y-%m-%d %H:%M:%S",
)
logger = logging.getLogger(__name__)


# =============================================================================
# ── Configuration ─────────────────────────────────────────────────────────────
# =============================================================================

# Columns with a null fraction strictly greater than this threshold are dropped.
NULL_DROP_THRESHOLD: float = 0.15   # 15 %

# Mapping of raw table  →  processed table for every ingestion source.
# Add new entries here as new data sources are onboarded.
RAW_TO_PROCESSED: dict[str, str] = {
    "raw_polygon":  "processed_polygon",
    "raw_census":   "processed_census",
    "raw_opensky":  "processed_opensky",
    "raw_oshub":    "processed_oshub",
    "raw_comtrade": "processed_comtrade",
}


# =============================================================================
# ── Data structures ───────────────────────────────────────────────────────────
# =============================================================================


class ColumnReport(NamedTuple):
    """Summary statistics for a single column before cleaning."""
    name:          str
    dtype:         str
    null_count:    int
    total_rows:    int
    null_fraction: float
    will_drop:     bool
    will_impute:   bool    # True only for numeric columns that survive Stage 1


class TableCleaningReport(NamedTuple):
    """Aggregate report for one table after the full cleaning pipeline."""
    table_name:         str
    rows:               int
    cols_before:        int
    cols_after:         int
    cols_dropped:       list[str]
    cols_imputed:       list[str]
    indicator_cols_added: list[str]


# =============================================================================
# ── Stage 0: Audit ─────────────────────────────────────────────────────────
# =============================================================================


def audit_nulls(df: pd.DataFrame, table_name: str) -> list[ColumnReport]:
    """
    Compute per-column null statistics and determine which columns will be
    dropped (Stage 1) or imputed (Stage 2).

    Args:
        df:         Raw DataFrame to audit.
        table_name: Name used in log messages.

    Returns:
        List of :class:`ColumnReport` — one entry per column, sorted by
        null fraction descending so the worst offenders appear first in logs.
    """
    n_rows = len(df)
    reports: list[ColumnReport] = []

    for col in df.columns:
        null_count    = int(df[col].isnull().sum())
        null_fraction = null_count / n_rows if n_rows > 0 else 0.0
        is_numeric    = pd.api.types.is_numeric_dtype(df[col])
        will_drop     = null_fraction > NULL_DROP_THRESHOLD
        # A column is eligible for imputation only if it:
        #   (a) is numeric, (b) survives column pruning, and (c) has at least
        #       one null that needs filling.
        will_impute   = is_numeric and (not will_drop) and (null_count > 0)

        reports.append(
            ColumnReport(
                name          = col,
                dtype         = str(df[col].dtype),
                null_count    = null_count,
                total_rows    = n_rows,
                null_fraction = null_fraction,
                will_drop     = will_drop,
                will_impute   = will_impute,
            )
        )

    # Sort by null fraction descending for informative log output
    reports.sort(key=lambda r: r.null_fraction, reverse=True)

    # ── Log a compact summary ──────────────────────────────────────────────
    n_drop   = sum(1 for r in reports if r.will_drop)
    n_impute = sum(1 for r in reports if r.will_impute)
    logger.info(
        "[%s] Null audit: %d rows | %d cols total | "
        "%d to DROP (>%.0f%% null) | %d numeric cols to IMPUTE",
        table_name, n_rows, len(reports),
        n_drop, NULL_DROP_THRESHOLD * 100, n_impute,
    )

    # Log every column that has at least one null — flagging drop/impute intent
    for rpt in reports:
        if rpt.null_fraction == 0.0:
            continue  # no nulls — nothing to report
        action = "DROP  ←" if rpt.will_drop else ("impute" if rpt.will_impute else "leave")
        logger.info(
            "[%s]   %-40s %5.1f%% null  (%d/%d)  → %s",
            table_name,
            rpt.name,
            rpt.null_fraction * 100,
            rpt.null_count,
            rpt.total_rows,
            action,
        )

    return reports


# =============================================================================
# ── Stage 1: Column pruning ───────────────────────────────────────────────────
# =============================================================================


def drop_high_null_columns(
    df: pd.DataFrame,
    reports: list[ColumnReport],
    table_name: str,
) -> tuple[pd.DataFrame, list[str]]:
    """
    Drop columns whose null fraction exceeds ``NULL_DROP_THRESHOLD``.

    Metadata / index columns that are entirely null are also dropped here
    (they would have null_fraction == 1.0 and thus pass the threshold test).

    Args:
        df:         DataFrame to prune.
        reports:    Pre-computed :class:`ColumnReport` list from :func:`audit_nulls`.
        table_name: Used in log messages.

    Returns:
        Tuple of (pruned DataFrame, list of dropped column names).
    """
    cols_to_drop = [r.name for r in reports if r.will_drop]

    if not cols_to_drop:
        logger.info(
            "[%s] Stage 1: No columns exceed the %.0f%% null threshold. "
            "Nothing dropped.",
            table_name, NULL_DROP_THRESHOLD * 100,
        )
        return df, []

    df_pruned = df.drop(columns=cols_to_drop)
    logger.info(
        "[%s] Stage 1: Dropped %d column(s): %s",
        table_name, len(cols_to_drop), cols_to_drop,
    )
    return df_pruned, cols_to_drop


# =============================================================================
# ── Stage 2: Numeric imputation with indicator columns ───────────────────────
# =============================================================================


def impute_numeric_columns(
    df: pd.DataFrame,
    reports: list[ColumnReport],
    table_name: str,
) -> tuple[pd.DataFrame, list[str], list[str]]:
    """
    For every numeric column that survived Stage 1 and still has nulls:

    1. Compute the column median on the non-null values.
    2. Insert a boolean ``<col>_was_null`` indicator column immediately to
       the right of the source column.
    3. Fill nulls in the source column with the computed median.

    The indicator column is inserted *before* imputation so that the boolean
    values faithfully reflect the original missing-data positions.

    Why adjacent insertion?
        Placing the indicator next to its source column makes the schema
        self-documenting — anyone reading the processed table immediately
        sees which values were imputed without consulting external metadata.

    Args:
        df:         DataFrame after Stage 1 pruning.
        reports:    Pre-computed :class:`ColumnReport` list (may reference
                    columns that were already dropped — they will be skipped).
        table_name: Used in log messages.

    Returns:
        Tuple of:
          - Cleaned DataFrame (in-place modifications on a copy)
          - List of column names that were imputed
          - List of new indicator column names that were added
    """
    # Work on a copy to avoid mutating the caller's DataFrame
    df = df.copy()

    # Only impute columns that (a) are still present after Stage 1 and
    # (b) were flagged for imputation during the audit.
    surviving_cols       = set(df.columns)
    cols_to_impute       = [
        r.name for r in reports
        if r.will_impute and r.name in surviving_cols
    ]

    imputed_cols:   list[str] = []
    indicator_cols: list[str] = []

    for col in cols_to_impute:
        null_count    = int(df[col].isnull().sum())
        null_fraction = null_count / len(df) if len(df) > 0 else 0.0
        col_median    = df[col].median(skipna=True)

        if pd.isna(col_median):
            # All values are null — this shouldn't happen after Stage 1 prunes
            # >15% null columns, but guard defensively.
            logger.warning(
                "[%s] Column '%s' has a NaN median (all values null?). "
                "Skipping imputation.",
                table_name, col,
            )
            continue

        indicator_name = f"{col}_was_null"

        # ── Guard: don't create a duplicate indicator column ──────────────
        if indicator_name in df.columns:
            logger.warning(
                "[%s] Indicator column '%s' already exists. "
                "Skipping re-creation.",
                table_name, indicator_name,
            )
        else:
            # Locate the current position of the source column and insert the
            # indicator immediately to its right.  We use get_loc() which
            # always returns the *current* position even after previous
            # insertions have shifted column indices.
            insert_pos = df.columns.get_loc(col) + 1
            df.insert(
                loc    = insert_pos,
                column = indicator_name,
                value  = df[col].isnull(),   # True where original value was NaN
            )
            indicator_cols.append(indicator_name)

        # ── Impute source column with median ──────────────────────────────
        df[col] = df[col].fillna(col_median)

        imputed_cols.append(col)
        logger.info(
            "[%s] Stage 2: Imputed '%s' — %d nulls (%.1f%%) → median=%.6g",
            table_name, col, null_count, null_fraction * 100, col_median,
        )

    if not imputed_cols:
        logger.info(
            "[%s] Stage 2: No numeric columns required imputation.", table_name
        )

    return df, imputed_cols, indicator_cols


# =============================================================================
# ── Full pipeline for a single table ─────────────────────────────────────────
# =============================================================================


def clean_table(
    df: pd.DataFrame,
    table_name: str,
) -> tuple[pd.DataFrame, TableCleaningReport]:
    """
    Apply the complete two-stage cleaning pipeline to a single DataFrame.

    Args:
        df:         Raw DataFrame loaded from Postgres.
        table_name: Source table name (used in all log and report output).

    Returns:
        Tuple of (cleaned DataFrame, :class:`TableCleaningReport`).
    """
    logger.info("")
    logger.info("─" * 65)
    logger.info("Cleaning table: '%s'  (%d rows × %d cols)", table_name, *df.shape)
    logger.info("─" * 65)

    cols_before = df.shape[1]

    # ── Stage 0: Audit ─────────────────────────────────────────────────────
    reports = audit_nulls(df, table_name)

    # ── Stage 1: Drop high-null columns ────────────────────────────────────
    df, dropped_cols = drop_high_null_columns(df, reports, table_name)

    # ── Stage 2: Median imputation + indicator columns ──────────────────────
    df, imputed_cols, indicator_cols = impute_numeric_columns(df, reports, table_name)

    cols_after = df.shape[1]

    # Verify no rows were lost (hard assertion — a bug here is a critical error)
    assert len(df) == reports[0].total_rows if reports else True, (
        f"Row count changed during cleaning of '{table_name}'! "
        f"Before: {reports[0].total_rows if reports else 'unknown'}, After: {len(df)}"
    )

    report = TableCleaningReport(
        table_name          = table_name,
        rows                = len(df),
        cols_before         = cols_before,
        cols_after          = cols_after,
        cols_dropped        = dropped_cols,
        cols_imputed        = imputed_cols,
        indicator_cols_added= indicator_cols,
    )

    logger.info(
        "[%s] Cleaning complete: %d cols → %d cols "
        "(%d dropped, %d imputed, %d indicators added)",
        table_name,
        cols_before, cols_after,
        len(dropped_cols), len(imputed_cols), len(indicator_cols),
    )

    return df, report


# =============================================================================
# ── Orchestration entry point ─────────────────────────────────────────────────
# =============================================================================


def main() -> None:
    """
    Iterate over all raw_* tables defined in ``RAW_TO_PROCESSED``, apply the
    cleaning pipeline to each, and write the result to the corresponding
    ``processed_*`` table.

    Tables that don't yet exist in the database (because their ingest script
    hasn't been run) are skipped with a warning rather than causing the whole
    pipeline to abort.  This lets you run clean_data.py incrementally after
    partial ingestion runs.
    """
    separator = "=" * 65

    logger.info(separator)
    logger.info("Supply Chain Pipeline — Data Cleaning Starting")
    logger.info("NULL DROP THRESHOLD: > %.0f%% nulls", NULL_DROP_THRESHOLD * 100)
    logger.info(separator)

    engine: Engine = get_engine()
    if not test_connection(engine):
        logger.critical(
            "Cannot reach the PostgreSQL database. "
            "Is docker compose up? Are the .env credentials correct? Exiting."
        )
        return

    # ── Introspect available tables ───────────────────────────────────────
    available_tables = set(list_tables(engine))

    # ── Track outcomes for the final summary ─────────────────────────────
    outcomes: dict[str, str] = {}
    all_reports: list[TableCleaningReport] = []

    for raw_table, processed_table in RAW_TO_PROCESSED.items():

        # ── Guard: raw table must exist ───────────────────────────────────
        if raw_table not in available_tables:
            logger.warning(
                "Table '%s' not found in the database — "
                "run the corresponding ingest script first. Skipping.",
                raw_table,
            )
            outcomes[raw_table] = "SKIPPED (table not found)"
            continue

        # ── Load raw data ─────────────────────────────────────────────────
        try:
            raw_df = read_table(raw_table, engine)
        except Exception as exc:
            logger.error("Failed to read '%s': %s. Skipping.", raw_table, exc)
            outcomes[raw_table] = f"ERROR (read): {exc}"
            continue

        if raw_df.empty:
            logger.warning(
                "Table '%s' exists but contains no rows. Skipping.", raw_table
            )
            outcomes[raw_table] = "SKIPPED (empty table)"
            continue

        # ── Apply cleaning pipeline ───────────────────────────────────────
        try:
            cleaned_df, report = clean_table(raw_df, raw_table)
            all_reports.append(report)
        except Exception as exc:
            logger.error(
                "Cleaning pipeline failed for '%s': %s",
                raw_table, exc, exc_info=True,
            )
            outcomes[raw_table] = f"ERROR (clean): {exc}"
            continue

        # ── Write processed table ─────────────────────────────────────────
        try:
            n_written = write_dataframe(
                cleaned_df,
                processed_table,
                engine,
                if_exists="replace",   # overwrite on each run for idempotency
            )
            outcomes[raw_table] = (
                f"OK → '{processed_table}' "
                f"({report.cols_before} cols → {report.cols_after} cols, "
                f"{n_written} rows)"
            )
        except Exception as exc:
            logger.error(
                "Failed to write '%s': %s", processed_table, exc, exc_info=True
            )
            outcomes[raw_table] = f"ERROR (write): {exc}"
            continue

    # =========================================================================
    # ── Final summary ──────────────────────────────────────────────────────
    # =========================================================================

    logger.info("")
    logger.info(separator)
    logger.info("Cleaning Pipeline Complete — Table Summary:")
    logger.info(separator)

    for raw_table, status in outcomes.items():
        logger.info("  %-25s %s", raw_table, status)

    if all_reports:
        logger.info("")
        logger.info("Detailed Column Changes:")
        logger.info("  %-25s %6s %6s %6s %6s %8s", "Table", "Rows", "ColsIn", "ColsOut", "Dropped", "Imputed")
        logger.info("  " + "-" * 65)
        for rpt in all_reports:
            logger.info(
                "  %-25s %6d %6d %6d %7d %8d",
                rpt.table_name,
                rpt.rows,
                rpt.cols_before,
                rpt.cols_after,
                len(rpt.cols_dropped),
                len(rpt.cols_imputed),
            )

    logger.info(separator)


if __name__ == "__main__":
    main()

