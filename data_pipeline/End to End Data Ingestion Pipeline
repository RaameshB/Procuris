# ── Component 4: Open Supply Hub — Facility & Supplier Network ────────────────
# =============================================================================


def _flatten_oshub_feature(feature: dict) -> dict:
    """
    Flatten a single GeoJSON Feature from the OS Hub API response into a
    flat dictionary suitable for a DataFrame row.

    OS Hub returns a FeatureCollection where each Feature has:
        - ``geometry``:   GeoJSON Point (longitude, latitude)
        - ``properties``: All facility metadata

    Args:
        feature: A single element from ``response["features"]``.

    Returns:
        Flat dict with all relevant fields extracted.
    """
    props    = feature.get("properties") or {}
    geometry = feature.get("geometry")   or {}
    coords   = geometry.get("coordinates") or []

    # Safely extract nested / list-type fields as plain strings so they
    # survive the DataFrame → Postgres round-trip without type issues.
    return {
        # ── Identity ──────────────────────────────────────────────────────
        "os_id":                props.get("os_id"),
        "name":                 props.get("name"),
        "address":              props.get("address"),
        "country_code":         props.get("country_code"),
        "country_name":         props.get("country_name"),
        # ── Classification ────────────────────────────────────────────────
        "sector":               str(props.get("sector",              [])),
        "sector_product_type":  str(props.get("sector_product_type", [])),
        "facility_type":        str(props.get("facility_type",       {})),
        # ── Workforce ─────────────────────────────────────────────────────
        "number_of_workers":    str(props.get("number_of_workers",   {})),
        # ── Certifications & status ───────────────────────────────────────
        "claim_status":         props.get("claim_status"),
        "is_closed":            props.get("is_closed"),
        # ── Geography ─────────────────────────────────────────────────────
        "longitude":            coords[0] if len(coords) > 0 else None,
        "latitude":             coords[1] if len(coords) > 1 else None,
        # ── Contribution metadata ─────────────────────────────────────────
        "contributor_count":    props.get("contributor_count"),
        "created_from":         props.get("created_from"),
    }


def ingest_oshub(engine) -> pd.DataFrame:
    """
    Pull facility and supplier network data from the Open Supply Hub (OS Hub)
    REST API, paginating through the full result set.

    The API returns a GeoJSON FeatureCollection. Each Feature represents one
    manufacturing or processing facility with location, sector, and worker-
    count metadata — critical inputs for supplier-network graph analysis.

    Pagination:
        The response includes a ``"next"`` URL for the following page.
        We follow it until it is null or an empty page is returned.

    Args:
        engine: SQLAlchemy engine from :func:`db_utils.get_engine`.

    Returns:
        DataFrame of facility records (written to ``raw_oshub``).
    """
    api_key = os.getenv("OSHUB_API_KEY", "").strip()
    if not api_key:
        logger.error(
            "[OSHub] OSHUB_API_KEY is not set in .env. "
            "Skipping Open Supply Hub ingestion."
        )
        return pd.DataFrame()

    headers = {
        "Authorization": f"Token {api_key}",
        "Accept":        "application/json",
    }

    all_records: list[dict] = []
    page = 1
    next_url: str | None = OSHUB_FACILITIES_URL

    logger.info("[OSHub] Starting paginated facility ingestion …")

    while next_url:
        params = {"page": page, "page_size": OSHUB_PAGE_SIZE} if page == 1 else None

        logger.info("[OSHub] Fetching page %d …", page)
        try:
            resp = _http_get(
                next_url,
                params=params,
                headers=headers,
            )
        except requests.HTTPError as exc:
            logger.error(
                "[OSHub] HTTP error on page %d: %s. Stopping pagination.", page, exc
            )
            break
        except RuntimeError as exc:
            logger.error(
                "[OSHub] All retries exhausted on page %d: %s. "
                "Stopping pagination.", page, exc,
            )
            break

        try:
            data: dict = resp.json()
        except requests.JSONDecodeError as exc:
            logger.error("[OSHub] Failed to parse JSON on page %d: %s", page, exc)
            break

        features: list = data.get("features", [])
        if not features:
            logger.info("[OSHub] Empty features list on page %d — pagination complete.", page)
            break

        page_records = [_flatten_oshub_feature(f) for f in features]
        all_records.extend(page_records)
        logger.info(
            "[OSHub] Page %d: %d facilities (running total: %d).",
            page, len(page_records), len(all_records),
        )

        # Follow the pagination cursor if the API provides one
        next_url = data.get("next")  # None → we've reached the last page
        page += 1

        if next_url:
            time.sleep(OSHUB_INTER_PAGE_SLEEP)

    if not all_records:
        logger.warning("[OSHub] No facility records retrieved.")
        return pd.DataFrame()

    df = pd.DataFrame(all_records)

    # Coerce numeric columns
    for col in ("longitude", "latitude", "contributor_count"):
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")

    df["ingested_at"] = pd.Timestamp.utcnow()

    logger.info("[OSHub] Total: %d facility records across %d page(s).", len(df), page - 1)
    write_dataframe(df, "raw_oshub", engine)
    return df


# =============================================================================
# ── Orchestration entry point ─────────────────────────────────────────────────
# =============================================================================


def main() -> None:
    """
    Run all four API ingestion tasks sequentially.

    Each task is independent — a failure in one does not abort the others.
    The final log line reports which tables were successfully written.
    """
    separator = "=" * 65

    logger.info(separator)
    logger.info("Supply Chain Pipeline — API Ingestion Starting")
    logger.info(separator)

    engine = get_engine()
    if not test_connection(engine):
        logger.critical(
            "Cannot reach the PostgreSQL database. "
            "Is docker compose up? Are the .env credentials correct? Exiting."
        )
        return

    results: dict[str, str] = {}

    # ── Task 1: Polygon.io ────────────────────────────────────────────────────
    logger.info("\n%s", "-" * 65)
    logger.info("[1/4] Polygon.io — Quarterly Financial Filings")
    logger.info("-" * 65)
    try:
        df_polygon = ingest_polygon(engine)
        results["raw_polygon"] = f"{len(df_polygon)} rows" if not df_polygon.empty else "EMPTY"
    except Exception as exc:
        logger.error("[Polygon] Fatal error: %s", exc, exc_info=True)
        results["raw_polygon"] = "ERROR"

    # ── Task 2: US Census Bureau ──────────────────────────────────────────────
    logger.info("\n%s", "-" * 65)
    logger.info("[2/4] US Census Bureau — M3 Manufacturing Survey")
    logger.info("-" * 65)
    try:
        df_census = ingest_census(engine)
        results["raw_census"] = f"{len(df_census)} rows" if not df_census.empty else "EMPTY"
    except Exception as exc:
        logger.error("[Census] Fatal error: %s", exc, exc_info=True)
        results["raw_census"] = "ERROR"

    # ── Task 3: OpenSky Network ───────────────────────────────────────────────
    logger.info("\n%s", "-" * 65)
    logger.info("[3/4] OpenSky Network — Aircraft State Vectors")
    logger.info("-" * 65)
    try:
        df_opensky = ingest_opensky(engine)
        results["raw_opensky"] = f"{len(df_opensky)} rows" if not df_opensky.empty else "EMPTY"
    except Exception as exc:
        logger.error("[OpenSky] Fatal error: %s", exc, exc_info=True)
        results["raw_opensky"] = "ERROR"

    # ── Task 4: Open Supply Hub ───────────────────────────────────────────────
    logger.info("\n%s", "-" * 65)
    logger.info("[4/4] Open Supply Hub — Facility & Supplier Network")
    logger.info("-" * 65)
    try:
        df_oshub = ingest_oshub(engine)
        results["raw_oshub"] = f"{len(df_oshub)} rows" if not df_oshub.empty else "EMPTY"
    except Exception as exc:
        logger.error("[OSHub] Fatal error: %s", exc, exc_info=True)
        results["raw_oshub"] = "ERROR"

    # ── Summary ───────────────────────────────────────────────────────────────
    logger.info("\n%s", separator)
    logger.info("API Ingestion Complete — Table Summary:")
    for table, status in results.items():
        logger.info("  %-25s %s", table, status)
    logger.info(separator)


if __name__ == "__main__":
    main()

