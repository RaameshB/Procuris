        time_slot_date  — YYYY-MM reference period
        seasonally_adj  — "yes"/"no" seasonal adjustment flag
        category_code   — Industry/product category (e.g. "MDM" = all mfg)
        data_type_code  — VS (Shipments), II (Inventories), NO (New Orders),
                          IO (Inventory/Orders ratio), BO (Backlog of Orders)

    The data covers the national aggregate and is invaluable for understanding
    macro-level supply-chain stress (inventory build / draw-down cycles).

    Args:
        engine: SQLAlchemy engine from :func:`db_utils.get_engine`.

    Returns:
        DataFrame of M3 survey records (also written to ``raw_census``).
    """
    api_key = os.getenv("CENSUS_API_KEY", "").strip()
    if not api_key:
        logger.error(
            "[Census] CENSUS_API_KEY is not set in .env. "
            "Skipping Census ingestion."
        )
        return pd.DataFrame()

    # ── Build query parameters ────────────────────────────────────────────────
    # The Census time-series API accepts time ranges like "from 2018" —
    # requests will URL-encode the space to "%20" automatically.
    params: dict[str, str] = {
        "get":  CENSUS_M3_GET_VARS,
        "time": f"from {CENSUS_M3_START_YEAR}",
        "key":  api_key,
    }

    logger.info(
        "[Census] Fetching M3 Manufacturing survey data (from %s) …",
        CENSUS_M3_START_YEAR,
    )

    try:
        resp = _http_get(CENSUS_M3_BASE_URL, params=params)
    except requests.HTTPError as exc:
        logger.error(
            "[Census] HTTP error fetching M3 data: %s. "
            "Verify your CENSUS_API_KEY and the endpoint URL.", exc,
        )
        return pd.DataFrame()
    except RuntimeError as exc:
        logger.error("[Census] All retries exhausted: %s", exc)
        return pd.DataFrame()

    # ── Parse response ────────────────────────────────────────────────────────
    try:
        payload: list[list[str]] = resp.json()
    except requests.JSONDecodeError as exc:
        logger.error("[Census] Failed to parse JSON response: %s", exc)
        return pd.DataFrame()

    if not payload or len(payload) < 2:
        logger.warning(
            "[Census] Response contained no data rows. "
            "The API may have returned an empty result set."
        )
        return pd.DataFrame()

    # First row is the header; subsequent rows are data.
    headers = payload[0]
    rows    = payload[1:]

    df = pd.DataFrame(rows, columns=headers)

    # ── Type coercions ────────────────────────────────────────────────────────
    for numeric_col in ("cell_value", "error_data"):
        if numeric_col in df.columns:
            df[numeric_col] = pd.to_numeric(df[numeric_col], errors="coerce")

    # Normalise the time column to a proper datetime
    if "time_slot_date" in df.columns:
        df["period_date"] = pd.to_datetime(
            df["time_slot_date"], format="%Y-%m", errors="coerce"
        )

    # Clean up whitespace in string columns
    str_cols = df.select_dtypes(include="object").columns
    df[str_cols] = df[str_cols].apply(lambda s: s.str.strip())

    # Add ingestion timestamp for auditability
    df["ingested_at"] = pd.Timestamp.utcnow()

    logger.info("[Census] Retrieved %d rows of M3 survey data.", len(df))
    write_dataframe(df, "raw_census", engine)
    return df


# =============================================================================
# ── Component 3: OpenSky Network — Flight / Cargo Transit ────────────────────
# =============================================================================


def ingest_opensky(engine) -> pd.DataFrame:
    """
    Pull a snapshot of all current aircraft state vectors from the OpenSky
    Network REST API.

    The ``/api/states/all`` endpoint returns the last known position and
    velocity data for every aircraft currently visible to the OpenSky sensor
    network (thousands of aircraft globally). This is used as a proxy for
    aggregate air-cargo and commercial transit activity.

    Authentication:
        - Anonymous: permitted, but limited to one request per 10 seconds.
        - Authenticated (OPENSKY_USERNAME / OPENSKY_PASSWORD): one request
          per 5 seconds and access to the 18th field (aircraft category).

    If credentials are missing from .env the script falls back to anonymous
    access with a warning.

    Args:
        engine: SQLAlchemy engine from :func:`db_utils.get_engine`.

    Returns:
        DataFrame of aircraft state vectors (written to ``raw_opensky``).
    """
    username = os.getenv("OPENSKY_USERNAME", "").strip()
    password = os.getenv("OPENSKY_PASSWORD", "").strip()

    if username and password:
        auth: tuple[str, str] | None = (username, password)
        logger.info("[OpenSky] Using authenticated access as user '%s'.", username)
    else:
        auth = None
        logger.warning(
            "[OpenSky] OPENSKY_USERNAME / OPENSKY_PASSWORD not set. "
            "Falling back to anonymous access (10 s rate limit applies)."
        )

    logger.info("[OpenSky] Fetching aircraft state vectors …")

    try:
        resp = _http_get(OPENSKY_STATES_URL, auth=auth)
    except requests.HTTPError as exc:
        logger.error("[OpenSky] HTTP error: %s", exc)
        return pd.DataFrame()
    except RuntimeError as exc:
        logger.error("[OpenSky] All retries exhausted: %s", exc)
        return pd.DataFrame()

    # ── Parse response ────────────────────────────────────────────────────────
    try:
        data: dict = resp.json()
    except requests.JSONDecodeError as exc:
        logger.error("[OpenSky] Failed to parse JSON response: %s", exc)
        return pd.DataFrame()

    states: list | None = data.get("states")
    if not states:
        logger.warning(
            "[OpenSky] No aircraft states in response — the network may be "
            "temporarily unavailable."
        )
        return pd.DataFrame()

    n_expected_cols = len(OPENSKY_STATE_COLUMNS)

    # ── Align variable-length state vectors to the column schema ──────────────
    # Authenticated responses include 18 elements; anonymous ones have 17.
    # We pad short rows with None and truncate over-long rows defensively.
    aligned_rows = [
        state[:n_expected_cols] + [None] * max(0, n_expected_cols - len(state))
        for state in states
    ]

    df = pd.DataFrame(aligned_rows, columns=OPENSKY_STATE_COLUMNS)

    # ── Type coercions ────────────────────────────────────────────────────────
    float_cols = [
        "time_position", "last_contact",
        "longitude", "latitude",
        "baro_altitude", "geo_altitude",
        "velocity", "true_track", "vertical_rate",
    ]
    for col in float_cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")

    bool_cols = ["on_ground", "spi"]
    for col in bool_cols:
        if col in df.columns:
            # Values arrive as Python bools already; cast to be explicit.
            df[col] = df[col].astype("boolean")

    # Trim trailing whitespace from callsigns (common in the raw feed)
    if "callsign" in df.columns:
        df["callsign"] = df["callsign"].str.strip().replace("", None)

    # Add request metadata for time-series analysis
    df["request_timestamp_utc"] = pd.Timestamp.utcnow()
    df["api_request_time"]      = data.get("time")  # Unix epoch from the API

    logger.info(
        "[OpenSky] Retrieved %d aircraft state records "
        "(auth=%s).",
        len(df), auth is not None,
    )
    write_dataframe(df, "raw_opensky", engine)
    return df


